<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/clCustomAlert"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <TextView
        android:id="@+id/tvPwdSetupTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_margin="4dp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="20sp"
        android:text="@string/create_password_title" />

    <TextView
        android:id="@+id/tvPwdSetupErrorMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvPwdSetupTitle"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etPwd1"
        android:layout_margin="4dp"
        android:textColor="@color/red_600"
        android:textSize="20sp"
        android:visibility="gone"
        android:text="@string/Error_PwdMissMatch"
        tools:visibility="visible" />

    <EditText
        android:id="@+id/etPwd1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvPwdSetupErrorMessage"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:maxLines="1"
        android:singleLine="true"
        android:lines="1"
        android:layout_margin="4dp"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:hint="Enter Password ..."/>

    <EditText
        android:id="@+id/etPwd2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/etPwd1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:maxLines="1"
        android:singleLine="true"
        android:lines="1"
        android:layout_margin="4dp"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:hint="Repeat Password ..."/>

</androidx.constraintlayout.widget.ConstraintLayout>